# Compiler files
cache/
cache_hardhat/
out/
artifacts/
typechain-types/

# Hardhat
node_modules/
# wagmi.config.ts imports the TallGrass deployment JSON at build time, so
# the SPA build (Netlify) needs that one file. Everything else under
# deployments/localhost stays local. (Negation only works against file
# globs, not directory globs — hence the trailing /* and explicit allow.)
deployments/localhost/*
!deployments/localhost/TallGrass.json

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Docs
docs/

# Render output
render/

# Dotenv file
.env

# Lock files
foundry.lock

# Dependencies managed as git submodules (forge install)
# Do not ignore lib/ — submodules are tracked by .gitmodules
